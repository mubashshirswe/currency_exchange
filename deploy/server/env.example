# cp env.example .env && nano .env
#
# MUHIM (deploydan keyin o'zgartirmang, aks holda userlar logout bo'ladi):
#   JWTSECRET, POSTGRES_PASSWORD, POSTGRES_DB, POSTGRES_USER

# github.repository → kichik harf: mubashshirswe/REPO_NOMI
API_IMAGE=ghcr.io/mubashshirswe/currency_exchange:latest

APP_PORT=8080
ENV=PROD
RUN_MIGRATIONS=true

POSTGRES_USER=app
# Parolda @ # : / bo'lishi mumkin — URL avtomatik encode qilinadi
POSTGRES_PASSWORD=KUCHLI_PAROL
POSTGRES_DB=currency_exchange
# DB_HOST/DB_PORT compose ichida (db:5432); lokalda DB_ADDR ham ishlatiladi

REDIS_PW=
REDIS_DB=0
REDIS_ENABLED=true

JWTSECRET=KUCHLI_RANDOM_JWT_SECRET
JWTExpirationInSeconds=86400

# Takroriy so'rov oynasi (sekund): bir xil create so'rov shu oyna ichida faqat bir marta bajariladi.
DEDUP_WINDOW_SECONDS=10

# Kompaniya balansi (company_balances) — default false, eski user-balans oqimi saqlanadi.
# true: tranzaksiyalar bilan bir vaqtda company_balances ham yangilanadi (keyingi bosqichda ulanadi).
COMPANY_LEDGER_ENABLED=false

# FCM: Firebase Console → Service accounts → JSON yuklab secrets/firebase.json ga qo'ying
FIREBASE_CREDENTIALS_PATH=
# FIREBASE_CREDENTIALS_PATH=/secrets/firebase.json
